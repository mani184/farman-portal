<!DOCTYPE html>
<html lang="sw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmanConnect - External Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Poppins', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f0fdf4',
                            100: '#dcfce7',
                            400: '#22c55e',
                            500: '#16a34a',
                            600: '#15803d',
                            700: '#166534',
                        },
                        accent: {
                            50: '#fdf4ff',
                            100: '#fce7f3',
                            500: '#ec4899',
                            600: '#db2777',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-out forwards',
                        'fade-in-up': 'fadeInUp 0.6s ease-out forwards',
                        'pulse-slow': 'pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'bounce-gentle': 'bounce 3s infinite',
                        'wiggle': 'wiggle 1s ease-in-out infinite',
                        'float': 'float 3s ease-in-out infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(30px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        },
                        wiggle: {
                            '0%, 100%': { transform: 'rotate(-3deg)' },
                            '50%': { transform: 'rotate(3deg)' },
                        },
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .glass {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
        }
        .gradient-primary {
            background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);
        }
        .gradient-accent {
            background: linear-gradient(135deg, #ec4899 0%, #db2777 100%);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 50%, #1e3a5f 100%);
        }
        .card-glow:hover {
            box-shadow: 0 0 30px rgba(34, 197, 94, 0.3);
        }
        .tab-active {
            background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);
            color: white;
        }
        .spinner {
            border: 4px solid rgba(255, 255, 255, 0.3);
            border-top: 4px solid #ffffff;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="min-h-screen gradient-bg font-sans">
    <!-- Header -->
    <header class="bg-white/10 backdrop-blur-md border-b border-white/20 animate-fade-in">
        <div class="max-w-4xl mx-auto px-4 py-5">
            <div class="flex items-center justify-center">
                <div class="flex items-center space-x-3">
                    <div class="w-14 h-14 bg-white/20 rounded-full flex items-center justify-center animate-float">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.14 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"></path>
                        </svg>
                    </div>
                    <div class="text-center">
                        <h1 class="text-3xl md:text-4xl font-bold text-white tracking-wide">FarmanConnect</h1>
                        <p class="text-green-400 text-sm mt-1">Internet Bora, Bei Nafuu</p>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8">
        <!-- Error Message -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 p-4 bg-red-100 border-l-4 border-red-500 text-red-700 rounded-r-lg animate-fade-in-up" role="alert">
                <div class="flex items-center">
                    <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span><%= error %></span>
                </div>
            </div>
        <% } %>

        <!-- Success Message -->
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="mb-6 p-4 bg-green-100 border-l-4 border-green-500 text-green-700 rounded-r-lg animate-fade-in-up" role="alert">
                <div class="flex items-center">
                    <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span><%= success %></span>
                </div>
            </div>
        <% } %>

        <!-- Show Payment Modal -->
        <% if (typeof showPayment !== 'undefined' && showPayment) { %>
            <div id="paymentModal" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 animate-fade-in">
                <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-md w-full mx-4 transform animate-fade-in-up">
                    <div class="text-center">
                        <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6 animate-pulse-slow">
                            <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <h2 class="text-2xl font-bold text-gray-800 mb-2">Subiri Malipo...</h2>
                        <p class="text-gray-600 mb-6">Tuma <span class="font-bold text-green-600 text-xl">TZS <%= amount.toLocaleString() %></span> kwenye namba ya simu yako</p>
                        
                        <div class="bg-gray-50 rounded-xl p-4 mb-6">
                            <p class="text-sm text-gray-500">Namba ya Simu</p>
                            <p class="text-2xl font-bold text-gray-800"><%= phone %></p>
                        </div>

                        <div class="flex justify-center mb-6">
                            <div class="spinner"></div>
                        </div>

                        <p class="text-gray-500 animate-pulse">Inacheking malipo... tafadhali subiri</p>

                        <button onclick="window.location.href='/'" class="mt-6 w-full bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-3 px-6 rounded-xl transition duration-300">
                            Ghairi
                        </button>
                    </div>
                </div>
            </div>

            <script>
                const transactionId = '<%= transactionId %>';
                let checkCount = 0;
                const maxChecks = 60;

                function checkPayment() {
                    fetch(`/check-payment/${transactionId}`)
                        .then(res => res.json())
                        .then(data => {
                            checkCount++;
                            
                            if (data.status === 'success') {
                                alert('Umefanikiwa! Namba ya vocha: ' + data.voucherCode);
                                window.location.href = '/';
                            } else if (data.status === 'voucher_error') {
                                alert('Hitilafu: ' + data.message);
                                window.location.href = '/';
                            } else if (data.status === 'expired') {
                                alert('Muda wa malipo umekwisha');
                                window.location.href = '/';
                            } else if (checkCount < maxChecks) {
                                setTimeout(checkPayment, 3000);
                            } else {
                                alert('Muda umekwisha, tafadhali jaribu tena');
                            }
                        })
                        .catch(err => {
                            if (checkCount < maxChecks) {
                                setTimeout(checkPayment, 3000);
                            }
                        });
                }
                setTimeout(checkPayment, 3000);
            </script>
        <% } %>

        <!-- Login Success Modal -->
        <% if (typeof showLoginSuccess !== 'undefined' && showLoginSuccess) { %>
            <div id="loginSuccessModal" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 animate-fade-in">
                <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-md w-full mx-4 transform animate-fade-in-up">
                    <div class="text-center">
                        <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                            <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <h2 class="text-2xl font-bold text-gray-800 mb-2">Umefanikiwa Kuingia!</h2>
                        <p class="text-gray-600 mb-6">Karibu! Unaweza sasa kutumia internet.</p>
                        <div class="bg-gray-50 rounded-xl p-4 mb-6">
                            <p class="text-sm text-gray-500">Vocha</p>
                            <p class="text-2xl font-bold text-gray-800"><%= voucherCode %></p>
                        </div>
                        <button onclick="window.location.href='/'" class="w-full gradient-primary hover:opacity-90 text-white font-semibold py-3 px-6 rounded-xl transition duration-300">
                            OK
                        </button>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Tab Navigation -->
        <div class="flex justify-center mb-8 animate-fade-in-up" style="animation-delay: 0.1s;">
            <div class="bg-white/10 rounded-2xl p-1 flex">
                <button onclick="showTab('buy')" id="tabBuy" class="tab-btn tab-active px-8 py-3 rounded-xl font-semibold transition-all duration-300 flex items-center space-x-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                    <span>Nunua Data</span>
                </button>
                <button onclick="showTab('voucher')" id="tabVoucher" class="tab-btn px-8 py-3 rounded-xl font-semibold text-white/70 hover:text-white transition-all duration-300 flex items-center space-x-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
                    </svg>
                    <span>Ingiza Vocha</span>
                </button>
            </div>
        </div>

        <!-- Buy Package Section -->
        <div id="sectionBuy" class="glass rounded-3xl shadow-2xl p-6 md:p-8 animate-fade-in-up">
            <div class="text-center mb-8">
                <h2 class="text-2xl font-bold text-gray-800">Chagua Kifurushi</h2>
                <p class="text-gray-500 mt-2">Bonyeza kifurushi unachohitaji</p>
            </div>

            <!-- Package Cards -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                <% packages.forEach((pkg, index) => { %>
                    <div 
                        class="package-card cursor-pointer p-5 border-3 border-gray-200 rounded-2xl hover:border-green-400 hover:shadow-xl transition-all duration-300 animate-fade-in-up card-glow bg-white"
                        style="animation-delay: <%= 0.1 + (index * 0.05) %>s;"
                        data-package-id="<%= pkg.id %>"
                        data-price="<%= pkg.price %>"
                        onclick="selectPackage('<%= pkg.id %>', '<%= pkg.price %>', '<%= pkg.name %>')"
                    >
                        <div class="text-center">
                            <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
                                <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                            <h3 class="font-bold text-lg text-gray-800"><%= pkg.name %></h3>
                            <p class="text-sm text-gray-500 mb-2"><%= pkg.duration %></p>
                            <p class="text-2xl font-bold text-green-600">TZS <%= pkg.price.toLocaleString() %></p>
                        </div>
                    </div>
                <% }); %>
            </div>

            <!-- Buy Form -->
            <form id="buyForm" action="/buy" method="POST" class="max-w-md mx-auto">
                <input type="hidden" id="selectedPackageId" name="packageId" value="">
                
                <div class="mb-6">
                    <label class="block text-gray-700 font-semibold mb-3" for="phone">
                        <span class="flex items-center">
                            <svg class="w-5 h-5 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                            </svg>
                            Namba ya Simu
                        </span>
                    </label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                            </svg>
                        </span>
                        <input 
                            type="tel" 
                            id="phone" 
                            name="phone" 
                            placeholder="0755 xxx xxx au 255..."
                            class="w-full pl-14 pr-4 py-4 border-3 border-gray-200 rounded-xl focus:border-green-500 focus:outline-none transition duration-300 text-lg"
                            required
                        >
                    </div>
                    <p class="text-xs text-gray-500 mt-2">Tuma Pesa, Tigo Pesa, M-Pesa au Airtel Money</p>
                </div>

                <div id="selectedPackageDisplay" class="hidden mb-6 p-4 bg-green-50 rounded-xl border-2 border-green-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-green-700">Kifurushi kilichochaguliwa:</p>
                            <p class="font-bold text-green-800 text-lg"><span id="selectedPackageName"></span></p>
                        </div>
                        <div class="text-right">
                            <p class="text-sm text-green-700">Jumla:</p>
                            <p class="font-bold text-green-800 text-xl">TZS <span id="selectedPackagePrice"></span></p>
                        </div>
                    </div>
                </div>

                <button 
                    type="submit" 
                    id="buyBtn"
                    disabled
                    class="w-full gradient-primary hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed text-white font-bold py-4 px-6 rounded-xl transition duration-300 flex items-center justify-center space-x-3 text-lg"
                >
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                    <span>Lipa Sasa</span>
                </button>
            </form>
        </div>

        <!-- Voucher Section (Hidden by default) -->
        <div id="sectionVoucher" class="hidden glass rounded-3xl shadow-2xl p-6 md:p-8 animate-fade-in-up">
            <div class="text-center mb-8">
                <h2 class="text-2xl font-bold text-gray-800">Ingiza Vocha</h2>
                <p class="text-gray-500 mt-2">Ingiza namba ya vocha yako</p>
            </div>

            <div class="max-w-md mx-auto">
                <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-2xl p-8 mb-8">
                    <div class="flex items-center justify-center mb-6">
                        <div class="w-20 h-20 bg-pink-100 rounded-full flex items-center justify-center animate-float">
                            <svg class="w-10 h-10 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
                            </svg>
                        </div>
                    </div>
                    <p class="text-gray-600 text-center">
                        Ikiwa una namba ya vocha tayari, ingiza hapa ili kuingia moja kwa moja.
                    </p>
                </div>

                <!-- Login Form -->
                <form action="/login" method="POST">
                    <div class="mb-6">
                        <label class="block text-gray-700 font-semibold mb-3" for="voucherCode">
                            <span class="flex items-center">
                                <svg class="w-5 h-5 mr-2 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                </svg>
                                Namba ya Vocha
                            </span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                </svg>
                            </span>
                            <input 
                                type="text" 
                                id="voucherCode" 
                                name="voucherCode" 
                                placeholder="Ingiza namba ya vocha"
                                class="w-full pl-14 pr-4 py-4 border-3 border-gray-200 rounded-xl focus:border-pink-500 focus:outline-none transition duration-300 text-lg font-mono"
                                required
                            >
                        </div>
                    </div>

                    <button 
                        type="submit" 
                        class="w-full gradient-accent hover:opacity-90 text-white font-bold py-4 px-6 rounded-xl transition duration-300 flex items-center justify-center space-x-3 text-lg"
                    >
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
                        </svg>
                        <span>Ingia</span>
                    </button>
                </form>

                <div class="mt-8 p-4 bg-gray-50 rounded-xl">
                    <p class="text-sm text-gray-600 text-center">
                        <strong class="text-gray-700">Msaada:</strong> Wasiliana na mtoa huduma wako ikiwauna tatizo
                    </p>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="mt-12 text-center text-white/60 text-sm animate-fade-in">
            <p>&copy; 2026 FarmanConnect. Haki zote zimehifadhiwa.</p>
        </footer>
    </main>

    <script>
        let selectedPackage = null;
        const packages = JSON.parse('<%- JSON.stringify(packages) %>');

        function showTab(tab) {
            const sectionBuy = document.getElementById('sectionBuy');
            const sectionVoucher = document.getElementById('sectionVoucher');
            const tabBuy = document.getElementById('tabBuy');
            const tabVoucher = document.getElementById('tabVoucher');
            
            if (tab === 'buy') {
                sectionBuy.classList.remove('hidden');
                sectionVoucher.classList.add('hidden');
                tabBuy.classList.add('tab-active');
                tabBuy.classList.remove('text-white/70');
                tabVoucher.classList.remove('tab-active');
                tabVoucher.classList.add('text-white/70');
            } else {
                sectionBuy.classList.add('hidden');
                sectionVoucher.classList.remove('hidden');
                tabVoucher.classList.add('tab-active');
                tabVoucher.classList.remove('text-white/70');
                tabBuy.classList.remove('tab-active');
                tabBuy.classList.add('text-white/70');
            }
        }

        function selectPackage(packageId, price, name) {
            selectedPackage = { id: packageId, price: price, name: name };
            
            // Update UI
            document.querySelectorAll('.package-card').forEach(card => {
                card.classList.remove('ring-4', 'ring-green-500', 'bg-green-50', 'border-green-500', 'shadow-xl');
                card.classList.add('border-gray-200');
            });

            // Highlight selected card
            const selectedCard = document.querySelector(`[data-package-id="${packageId}"]`);
            selectedCard.classList.remove('border-gray-200');
            selectedCard.classList.add('ring-4', 'ring-green-500', 'bg-green-50', 'border-green-500', 'shadow-xl');

            // Update form
            document.getElementById('selectedPackageId').value = packageId;
            document.getElementById('selectedPackageDisplay').classList.remove('hidden');
            document.getElementById('selectedPackageName').textContent = name;
            document.getElementById('selectedPackagePrice').textContent = Number(price).toLocaleString();

            // Enable buy button
            document.getElementById('buyBtn').disabled = false;
        }

        document.getElementById('buyForm').addEventListener('submit', function(e) {
            if (!selectedPackage) {
                e.preventDefault();
                alert('Tafadhali chagua kifurushi kwanza');
            }
        });
    </script>
</body>
</html>
